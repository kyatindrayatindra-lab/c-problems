#include <stdio.h>

int main() {
int capacity, N;
int change;
int occupied = 0;
int i = 0;
int criticalCount = 0;
float threshold;


scanf("%d", &capacity);
scanf("%d", &N);

threshold = 0.9 * capacity;

while (i < N) {
scanf("%d", &change);

occupied += change;

if (occupied < 0) {
occupied = 0;
}

if (occupied > threshold) {
criticalCount++;
}

i++;
}

printf("Final Occupied Beds: %d\n", occupied);
printf("Critical Hours: %d\n", criticalCount);

return 0;
}
