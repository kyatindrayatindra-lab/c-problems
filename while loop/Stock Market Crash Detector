#include <stdio.h>

int main()
{
int N;
int i = 1;
int prev, curr;
int drops = 0;
int consecutiveDrops = 0;
int crashDay = -1;

scanf("%d", &N);

scanf("%d", &prev);

while(i < N)
{
scanf("%d", &curr);

if(curr < prev)
{
drops++;
consecutiveDrops++;

if(consecutiveDrops == 3 && crashDay == -1)
crashDay = i + 1;
}
else
{

consecutiveDrops = 0;
}

prev = curr;
i++;
}

if(crashDay == -1)
printf("Crash Day: Not Detected\n");
else
printf("Crash Day: %d\n", crashDay);

printf("Total Drops: %d", drops);

return 0;
}
