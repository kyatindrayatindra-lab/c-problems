#include <stdio.h>

int main() {
int N, count = 0;
int unsafeCount = 0, consecutiveUnsafe = 0;
int breakdownPoint = -1;

scanf("%d", &N);

while(count < N) {
int vibration;
scanf("%d", &vibration);

if(vibration > 70) {
unsafeCount++;
consecutiveUnsafe++;

if(consecutiveUnsafe == 3 && breakdownPoint == -1) {
breakdownPoint = count + 1;
}
} else {
consecutiveUnsafe = 0;
}

count++;
}

if(breakdownPoint != -1)printf("Breakdown At Reading: %d\n", breakdownPoint);
else
printf("Breakdown At Reading: Not Occurred\n");

printf("Unsafe Readings: %d\n", unsafeCount);

return 0;
}
