#include <stdio.h>

int main() {
int totalData;
scanf("%d", &totalData);

int N;
scanf("%d", &N);

int usage;
int i = 0;
int daysUsed = 0;

while (i < N && totalData > 0) {
scanf("%d", &usage);

totalData -= usage;

if (totalData >= 0) {
daysUsed++;
} else {
totalData = 0;
}

i++;
}

printf("Days Used: %d\n", daysUsed);
printf("Remaining Data: %dGB\n", totalData);

return 0;
}
