#include <stdio.h>

int main() {
int N;
scanf("%d", &N);

int hours, totalHours = 0, heavyDays = 0;

for(int i = 0; i < N; i++) {
scanf("%d", &hours);
totalHours += hours;

if(hours > 3)
heavyDays++;
}

int cost = totalHours * 200;

printf("Total Overtime Hours: %d\n", totalHours);
printf("Overtime Cost: %d\n", cost);
printf("Heavy Overtime Days: %d\n", heavyDays);

return 0;
}
