#include <stdio.h>

int main() {
 int N, num;
 int even = 0, odd = 0;

 printf("Enter number of days: ");
 scanf("%d", &N);

printf("Enter the day numbers:\n");

for(int i = 0; i < N; i++) {
 scanf("%d", &num);

 if(num % 2 == 0) {
  even++;
 } else {
odd++;
 }
    }

    printf("Even:%d Odd:%d\n", even, odd);

    return 0;
}
