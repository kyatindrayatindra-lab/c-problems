#include <stdio.h>

int main() {
int n, i;

printf("Enter number of elements: ");
scanf("%d", &n);

int arr[n];

printf("Enter elements:\n");
for(i = 0; i < n; i++) {
scanf("%d", &arr[i]);
}

int max = arr[n-1];
arr[n-1] = -1;

for(i = n-2; i >= 0; i--) {
int temp = arr[i];
arr[i] = max;

if(temp > max) {
max = temp;
}
}

printf("Modified array:\n");
for(i = 0; i < n; i++) {
printf("%d ", arr[i]);
}

return 0;
}
