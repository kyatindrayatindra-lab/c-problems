#include <stdio.h>

int main() {
    int n, i, price;
    int min = 0;       
    int found = 0;     

    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        scanf("%d", &price);

        if(price > 0) {
            if(found == 0) {
                min = price;   
                found = 1;
            } else if(price < min) {
                min = price;
            }
        }
    }

    if(found == 0)
        printf("No positive");
    else
        printf("%d", min);

    return 0;
}
