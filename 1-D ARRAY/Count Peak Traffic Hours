#include <stdio.h>

int main() {
    int n, i, count = 0;

    printf("Enter number of hours: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter traffic data:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    for(i = 1; i < n - 1; i++) {
        if(arr[i] > arr[i - 1] && arr[i] > arr[i + 1]) {
            count++;
        }
    }

    printf("Peak count = %d\n", count);

    return 0;
}
