#include <stdio.h>

int main() {
    int n, k, i;
    
    // Input size of array
    scanf("%d", &n);
    
    int arr[n], temp[n];
    
   
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    
    
    scanf("%d", &k);

    
    for(i = 0; i < n - k; i++) {
        temp[i] = arr[i + k];
    }

    for(i = 0; i < k; i++) {
        temp[n - k + i] = arr[i];
    }

    
    for(i = 0; i < n; i++) {
        printf("%d ", temp[i]);
    }

    return 0;
}
