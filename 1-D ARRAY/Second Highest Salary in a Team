#include<stdio.h>

int main()
{
int n,i;
int a[100];
int max=-1, second=-1;

printf("Enter number of employees: ");
scanf("%d",&n);

printf("Enter salaries:\n");
for(i=0;i<n;i++)
scanf("%d",&a[i]);

for(i=0;i<n;i++)
{
if(a[i] > max)
{
second = max;
max = a[i];
}
else if(a[i] > second && a[i] != max)
{
second = a[i];
}
}

printf("Second highest salary = %d",second);

return 0;
}
