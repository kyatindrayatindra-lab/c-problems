#include <stdio.h>

int main() {
    int arr[100], n, i, sum = 0;
    float avg;

    printf("Enter size: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];
    }

    avg = sum / (float)n;

    printf("Sum = %d\n", sum);
    printf("Average = %.2f\n", avg);

    return 0;
}
