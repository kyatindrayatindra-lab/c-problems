#include <stdio.h>

int main() {
    int n, i;
    float sum = 0, avg;
    
    printf("Enter number of students: ");
    scanf("%d", &n);

    int marks[n];

    printf("Enter marks:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &marks[i]);
        sum += marks[i];
    }

    avg = sum / n;

    int count = 0;

    for(i = 0; i < n; i++) {
        if(marks[i] > avg) {
            count++;
        }
    }

    printf("Count of students above average: %d\n", count);

    return 0;
}
