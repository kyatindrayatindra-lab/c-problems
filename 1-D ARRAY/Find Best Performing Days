#include <stdio.h>

int main()
{
    int n, i;

    printf("Enter number of days: ");
    scanf("%d", &n);

    int a[n];

    printf("Enter performance values:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }

    int max = a[n-1];

    printf("Leader values: %d ", max);

    for(i = n-2; i >= 0; i--)
    {
        if(a[i] > max)
        {
            printf("%d ", a[i]);
            max = a[i];
        }
    }

    return 0;
}
