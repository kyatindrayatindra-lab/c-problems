#include <stdio.h>

int main()
{
int n = 4;
int size = 2 * n - 1;

for(int i = 0; i < size; i++)
{
for(int j = 0; j < size; j++)
{
int top = i;
int left = j;   
 int right = size - j - 1;
int bottom = size - i - 1;

int min = top;

if(left < min) min = left;
if(right < min) min = right;
if(bottom < min) min = bottom;

printf("%d ", n - min);
}
printf("\n");
}
return 0;
}
