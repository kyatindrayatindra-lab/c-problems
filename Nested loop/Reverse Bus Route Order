#include <stdio.h>

int main() {
int n, i, j, temp;

printf("Enter number of stops: ");
scanf("%d", &n);

int stops[n];

printf("Enter the stops:\n");
for(i = 0; i < n; i++) {
scanf("%d", &stops[i]);
}

   
i = 0;
j = n - 1;

while(i < j) {
temp = stops[i];
stops[i] = stops[j];
stops[j] = temp;

i++;
j--;
}

printf("Reversed route:\n");
for(i = 0; i < n; i++) {
printf("%d ", stops[i]);
}

return 0;
}
